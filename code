#include <ESP8266WiFi.h>
#include <WiFiClientSecure.h>
#include <ESP8266HTTPClient.h>
#include <ArduinoJson.h>
#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_GC9A01A.h>
#include <cmath>

// --- WiFi Credentials ---
const char* ssid     = ;       // replace this with your wifi NAME
const char* password = ;         // replace this with your wifi password

// --- OpenSky Account API Client Details ---
const char* client_id     = ;   //replace this with your open sky username
const char* client_secret = ;  //replace this with the secret code the website gave you

// Bounding Box
// These define the geographical area for which flight data will be fetched.
// Adjust these values to change your radar's coverage area.
const char* lamin = "54.20";
const char* lomin = "19.50"; 
const char* lamax = "59.60"; 
const char* lomax = "28.50"; 

// Center coordinates for your radar display (e.g., Riga, Latvia)
const float RIX_LAT = 56.9236;  // THE coordinates for the center, you need to change the blue number
const float RIX_LON = 23.9711;  // the coordinates for the center 

// Maximum range of the radar in kilometers. Flights beyond this distance will not be displayed.
// Keep this value reasonable to avoid clutter and memory issues.
const float MAX_RADAR_RANGE_KM = 80.0;

// Display Dimensions
#define TFT_WIDTH  240
#define TFT_HEIGHT 240

// --- Pin Definitions for Adafruit_GC9A01A (Wemos D1 Mini) ---
#define TFT_DC D2 // GPIO04 on Wemos D1 Mini
#define TFT_CS D8 // GPIO15 on Wemos D1 Mini

// --- Color Definitions (Adafruit_GFX format - 16-bit RGB565) ---
#define BLACK       0x0000
#define GREEN       0x07E0
#define DARKGREEN   0x03E0

// Adafruit_GC9A01A object for display control
Adafruit_GC9A01A tft(TFT_CS, TFT_DC);

// Token tracking variables for OpenSky API authentication
String accessToken = "";
unsigned long tokenExpiryTime = 0; // Time when the access token expires (in milliseconds since board startup)
int backoffSeconds = 15;           // Delay between API calls, adjusted based on API response

// Forward declarations for functions
void drawRadarGrid();
bool refreshOpenSkyToken();
void fetchAndMapFlights();
void drawCenterString(const String& buf, int x, int y, int font);

void setup() {
  Serial.begin(115200); // Initialize serial communication for debugging

  // --- Initialize the TFT display  ---
  tft.begin(); 
  tft.setRotation(0); // Set display rotation (0-3)
  tft.fillScreen(BLACK); // Clear the screen to black

  drawRadarGrid();
  tft.setTextColor(GREEN); // Set text color to green
  // Using the helper function for centering
  drawCenterString("Connecting WiFi...", TFT_WIDTH / 2, TFT_HEIGHT / 2 - 8, 2);

  WiFi.begin(ssid, password); // Start WiFi connection
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);         // Wait for connection
    Serial.print(".");  // Print dots to serial monitor while connecting
  }
  Serial.println("\nWiFi Connected!"); // Notify successful connection

  tft.fillScreen(BLACK);      // Clear screen after connection
  drawRadarGrid();            // Redraw grid
  drawCenterString("Radar Active", TFT_WIDTH / 2, TFT_HEIGHT / 2 - 8, 2);
  delay(1500);                // Short delay to show the message
}

void loop() {
  if (WiFi.status() == WL_CONNECTED) {
    // Check if the access token is empty or expired
    if (accessToken == "" || millis() >= tokenExpiryTime) {
      tft.fillRect(20, 110, 200, 20, BLACK);                          // Clear authentication message area
      drawCenterString("Authenticating...", TFT_WIDTH / 2, 112, 2);

      if (!refreshOpenSkyToken()) {
        delay(10000);
        return;
      }
    }
    fetchAndMapFlights();
  } else {
    Serial.println("WiFi Disconnected, attempting reconnect...");
    WiFi.begin(ssid, password);
    tft.fillRect(20, 110, 200, 20, BLACK);
    drawCenterString("WiFi Disconnected", TFT_WIDTH / 2, 112, 2);
    delay(2000);
  }
  delay(backoffSeconds * 1000);
}

// Function to refresh the OpenSky API access token
bool refreshOpenSkyToken() {
  WiFiClientSecure client;
  client.setInsecure();

  HTTPClient http;
  http.begin(client, "https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token");
  http.addHeader("Content-Type", "application/x-www-form-urlencoded");

  String postData = "grant_type=client_credentials&client_id=" + String(client_id) + "&client_secret=" + String(client_secret);

  int httpCode = http.POST(postData);
  if (httpCode == 200) {
    String payload = http.getString();
    Serial.print("Auth Payload: "); Serial.println(payload);

    DynamicJsonDocument doc(512);
    DeserializationError error = deserializeJson(doc, payload);

    if (!error) {
      String token = doc["access_token"].as<String>();
      long expiresIn = doc["expires_in"].as<long>();

      if (token != "null" && token.length() > 0) {
        accessToken = token;
        tokenExpiryTime = millis() + ((expiresIn - 60) * 1000);
        Serial.println("OAuth2 Token generation complete.");
        http.end();
        return true;
      }
    } else {
      Serial.printf("JSON deserialization failed for token: %s\n", error.c_str());
    }
  }

  Serial.printf("Authentication pipeline failed. HTTP: %d\n", httpCode);
  tft.fillRect(20, 110, 200, 20, BLACK);
  drawCenterString("AUTH ERR: " + String(httpCode), TFT_WIDTH / 2, 112, 2);
  http.end();
  return false;
}

// Function to fetch and map flight data on the radar display
void fetchAndMapFlights() {
  WiFiClientSecure client;
  client.setInsecure();

  HTTPClient http;
  String url = "https://opensky-network.org/api/states/all";
  url += "?lamin=" + String(lamin) + "&lomin=" + String(lomin) + "&lamax=" + String(lamax) + "&lomax=" + String(lomax);

  http.begin(client, url);
  http.addHeader("Authorization", "Bearer " + accessToken);

  int httpCode = http.GET();
  Serial.printf("Flight Data HTTP Code: %d\n", httpCode);

  if (httpCode == 200) {
    backoffSeconds = 15;
    String payload = http.getString();

    DynamicJsonDocument doc(32768);

    DeserializationError error = deserializeJson(doc, payload);
    if (error) {
      Serial.printf("JSON deserialization failed: %s\n", error.c_str());
      http.end();
      return;
    }

    tft.fillScreen(BLACK);
    drawRadarGrid();

    JsonArray states = doc["states"];
    int totalPlanesFound = states.size();
    int plottedCount = 0;

    int lastDrawnX = -100;
    int lastDrawnY = -100;

    int altFeet = 0;

    for (int i = 0; i < totalPlanesFound; i++) {
      JsonArray plane = states[i];

      String callsign = plane[1].as<String>();
      String squawk = plane[14].as<String>();

      callsign.trim();
      if (callsign.length() == 0 || callsign == "null") {
        callsign = "[AC]";
      }

      if (!plane[5].is<float>() || !plane[6].is<float>()) {
        Serial.println("Invalid latitude or longitude for a plane, skipping.");
        continue;
      }

      float lon = plane[5].as<float>();
      float lat = plane[6].as<float>();
      float altMeters = plane[7].as<float>();

      if (lat == 0 || lon == 0) continue;

      altFeet = (int)(altMeters * 3.28084);

      float dLat = lat - RIX_LAT;
      float dY = dLat * 111.1;
      float dLon = lon - RIX_LON;
      float dX = dLon * 111.1 * cos(RIX_LAT * PI / 180.0);
      float distanceKM = sqrt(dX * dX + dY * dY);

      if (distanceKM > MAX_RADAR_RANGE_KM) continue;

      plottedCount++;

      float pixelRadius = (distanceKM / MAX_RADAR_RANGE_KM) * 115.0;

      float angle = atan2(dX, dY);

      int screenX = 120 + (int)(pixelRadius * sin(angle));
      int screenY = 120 - (int)(pixelRadius * cos(angle));

      tft.fillCircle(screenX, screenY, 3, GREEN);
      tft.setTextColor(GREEN);
      tft.setTextSize(1); // Set text size for labels (smallest font)

      if (screenY > 38 && screenY < 195) {
        int textXOffset = 5;
        int textYOffset = -7;

        if (abs(screenY - lastDrawnY) < 12 && abs(screenX - lastDrawnX) < 40) {
          textYOffset += 14;
        }

        if (screenX > 175) {
          textXOffset = -45;
        } else if (screenX < 45) {
          textXOffset = 6;
        }

        lastDrawnX = screenX + textXOffset;
        lastDrawnY = screenY + textYOffset;

        tft.setCursor(lastDrawnX, lastDrawnY);
        tft.print(callsign);
        if (altMeters > 0 && plane[7].is<float>()) {
          tft.setCursor(lastDrawnX, lastDrawnY + 9);
          tft.print(String(altFeet / 100) + "00f");
        } else {
          tft.setCursor(lastDrawnX, lastDrawnY + 9);
          tft.print("GND");
        } /*    Uncomment this part to see show squawk
        if (squawk.length() != 0 && callsign != "null") {
          tft.setCursor(lastDrawnX, lastDrawnY + 18);
          tft.print(squawk);
        }*/
      }
    }

    // After plotting all planes, redraw static elements to ensure they are on top
    // Clear old "RIX RADAR" area and "TRAFFIC" area
    tft.fillRect(0, 0, TFT_WIDTH, 20, BLACK); // Clear top area
    tft.fillRect(0, TFT_HEIGHT - 20, TFT_WIDTH, 20, BLACK); // Clear bottom area
    drawRadarGrid();

    tft.setTextColor(GREEN);
    drawCenterString("RADAR", TFT_WIDTH / 2, 10, 1);

    String trafficString = "TRAFFIC: " + String(plottedCount);
    drawCenterString(trafficString, TFT_WIDTH / 2, 215, 1);

    if (plottedCount == 0) {
      drawCenterString("SKY CLEAR", TFT_WIDTH / 2, 115, 2);
    }
  }
  else {
    Serial.printf("HTTP Failed: %d\n", httpCode);
    tft.fillRect(30, 110, 180, 20, BLACK);
    drawCenterString("API ERR: " + String(httpCode), TFT_WIDTH / 2, 112, 2);
    if (httpCode == 429) {
      drawCenterString("RATE COOLDOWN", TFT_WIDTH / 2, 112, 2);
      backoffSeconds = 60;
    } else {
      drawCenterString("API ERR: " + String(httpCode), TFT_WIDTH / 2, 112, 2);
      backoffSeconds = 20;
    }
  }
  http.end();
}

// Function to draw the static radar grid on the TFT display
void drawRadarGrid() {
  // Draw concentric circles representing distance ranges
  tft.drawCircle(120, 120, 35,  DARKGREEN); // Inner circle
  tft.drawCircle(120, 120, 75,  DARKGREEN); // Middle circle
  tft.drawCircle(120, 120, 115, GREEN);     // Outermost circle

  // Draw crosshairs (horizontal and vertical lines)
  tft.drawLine(5, 120, 235, 120, DARKGREEN); // Horizontal line across the screen
  tft.drawLine(120, 5, 120, 235, DARKGREEN); // Vertical line across the screen
  tft.fillRect(118, 118, 4, 4, GREEN);       // Small square at the center
}

// Helper function to draw a string centered at a given (x, y) coordinate
// This function calculates the width of the string using the current font size
// and then adjusts the cursor to center the text.
// 'font' parameter is equivalent to setTextSize() for Adafruit_GFX built-in font.
void drawCenterString(const String& buf, int x, int y, int font) {
  tft.setTextSize(font); // Set the font size
  int16_t x1, y1;
  uint16_t w, h;
  tft.getTextBounds(buf, 0, 0, &x1, &y1, &w, &h); // Get text bounds without drawing
  tft.setCursor(x - w / 2, y); // Set cursor to center the text horizontally
  tft.print(buf);
}
