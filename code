#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h>
#include <SPI.h>
#include <TFT_eSPI.h>
#include <cmath> 

// --- Configuration ---
const char* ssid     = "XXXXXXXXXXXX";       // replace this with your wifi NAME
const char* password = "XXXXXXXXXX";         // replace this with your wifi password

// --- OpenSky Account API Client Details ---
const char* client_id     = "XXXXXXXXXXXXXXXXXXXXXXXXX";   //replace this with your open sky username, it  is free to make one
const char* client_secret = "XXXXXXXXXXXXXXXXXXXXXXXXXXXX";  //replace this with the secret code the website gives you

// Bounding Box (300km+ radius around Riga)
const char* lamin = "54.20"; 
const char* lomin = "19.50"; 
const char* lamax = "59.60"; 
const char* lomax = "28.50"; 

const float RIX_LAT = 56.9236;  // THE coordinates for the center, you need to change the blue number
const float RIX_LON = 23.9711;   // the coordinates for the center 
const float MAX_RADAR_RANGE_KM = 200.0;  // this is max distance, i recommend not making this bigger or even smaller, otherwise the radar gets too clutterd.

TFT_eSPI tft = TFT_eSPI();

// Token tracking variables
String accessToken = "";
unsigned long tokenExpiryTime = 0; 
int backoffSeconds = 15; 

void drawRadarGrid();
bool refreshOpenSkyToken();

void setup() {
  Serial.begin(115200);
  
  tft.init();
  tft.setRotation(0);
  tft.fillScreen(TFT_BLACK);
  
  drawRadarGrid();
  tft.setTextColor(TFT_GREEN);
  tft.drawCentreString("Connecting WiFi...", 120, 120, 2); 

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  
  tft.fillScreen(TFT_BLACK);
  drawRadarGrid();
  tft.drawCentreString("Radar Active", 120, 120, 2);
  delay(1500);
}

void loop() {
  if (WiFi.status() == WL_CONNECTED) {
    // Automatically manage token rotation securely before running radar sweeping
    if (accessToken == "" || millis() >= tokenExpiryTime) {
      tft.fillRect(20, 110, 200, 20, TFT_BLACK);
      tft.drawCentreString("Authenticating...", 120, 112, 2);
      
      if (!refreshOpenSkyToken()) {
        delay(10000); // Fail safety: Wait 10 seconds before looping back to try again
        return;
      }
    }
    fetchAndMapFlights();
  } else {
    WiFi.begin(ssid, password);
  }
  delay(backoffSeconds * 1000); 
}

// Intercepts OpenSky Identity server using Client Credentials flow
bool refreshOpenSkyToken() {
  HTTPClient http;
  // Official Keycloak server endpoint for OpenSky authentication
  http.begin("https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token");
  http.addHeader("Content-Type", "application/x-www-form-urlencoded");
  
  // Format matching the exact OAuth2 payload requirements
  String postData = "grant_type=client_credentials&client_id=" + String(client_id) + "&client_secret=" + String(client_secret);
  
  int httpCode = http.POST(postData);
  if (httpCode == 200) {
    String payload = http.getString();
    JsonDocument doc;
    DeserializationError error = deserializeJson(doc, payload);
    
    if (!error) {
      String token = doc["access_token"].as<String>();
      long expiresIn = doc["expires_in"].as<long>(); 
      
      if (token != "null" && token.length() > 0) {
        accessToken = token;
        tokenExpiryTime = millis() + ((expiresIn - 60) * 1000); // 1-minute safety buffer offset
        Serial.println("OAuth2 Token generation complete.");
        return true;
      }
    }
  }
  
  // Debug output straight to screen face if secret keys don't align
  Serial.printf("Authentication pipeline failed. HTTP: %d\n", httpCode);
  tft.fillRect(20, 110, 200, 20, TFT_BLACK);
  tft.drawCentreString("AUTH ERR: " + String(httpCode), 120, 112, 2);
  return false;
}

void fetchAndMapFlights() {
  HTTPClient http;
  String url = "https://opensky-network.org/api/states/all";
  url += "?lamin=" + String(lamin) + "&lomin=" + String(lomin) + "&lamax=" + String(lamax) + "&lomax=" + String(lomax);
  
  http.begin(url);
  
  // Inject generated Bearer token directly into HTTP transactions
  http.addHeader("Authorization", "Bearer " + accessToken);
  
  int httpCode = http.GET();
  
  if (httpCode == 200) {
    backoffSeconds = 15; // Reset tracking pace
    String payload = http.getString();
    
    JsonDocument doc; 
    DeserializationError error = deserializeJson(doc, payload);
    if (error) return;
    
    tft.fillScreen(TFT_BLACK);
    drawRadarGrid();
    
    JsonArray states = doc["states"];
    int totalPlanesFound = states.size();
    int plottedCount = 0;
    
    int lastDrawnX = -100;
    int lastDrawnY = -100; 

    for (int i = 0; i < totalPlanesFound; i++) {
      JsonArray plane = states[i];
      
      String callsign = plane[1].as<String>();
      callsign.trim();
      if (callsign.length() == 0 || callsign == "null") {
        callsign = "[AC]"; 
      }
      
      float lon = plane[5].as<float>();
      float lat = plane[6].as<float>();
      float altMeters = plane[7].as<float>();
      int altFeet = (int)(altMeters * 3.28084);
      
      if (lat == 0 || lon == 0) continue;

      float dLat = lat - RIX_LAT;
      float dY = dLat * 111.1; 
      float dLon = lon - RIX_LON;
      float dX = dLon * 111.1 * cos(RIX_LAT * PI / 180.0);
      float distanceKM = sqrt(dX * dX + dY * dY);
      
      if (distanceKM > MAX_RADAR_RANGE_KM) continue;
      
      plottedCount++; 

      float pixelRadius = 0;
      if (distanceKM <= 10.0) {
        pixelRadius = (distanceKM / 10.0) * 35.0;
      } 
      else if (distanceKM <= 100.0) {
        pixelRadius = 35.0 + ((distanceKM - 10.0) / 90.0) * 40.0;
      } 
      else {
        pixelRadius = 75.0 + ((distanceKM - 100.0) / 200.0) * 40.0;
      }
      
      float angle = atan2(dX, dY);
      int screenX = 120 + (int)(pixelRadius * sin(angle));
      int screenY = 120 - (int)(pixelRadius * cos(angle)); 
      
      tft.fillCircle(screenX, screenY, 3, TFT_GREEN); 
      tft.setTextColor(TFT_GREEN);
      tft.setTextFont(1); 
      
      if (screenY > 38 && screenY < 195) {
        int textXOffset = 5;
        int textYOffset = -7;
        
        if (abs(screenY - lastDrawnY) < 12 && abs(screenX - lastDrawnX) < 40) { 
          textYOffset += 14; 
        }
        
        if (screenX > 175) {
          textXOffset = -45; 
        } else if (screenX < 45) {
          textXOffset = 6;
        }

        lastDrawnX = screenX;
        lastDrawnY = screenY + textYOffset;

        tft.drawString(callsign, screenX + textXOffset, screenY + textYOffset);
        if (altMeters > 0) {
          tft.drawString(String(altFeet / 100) + "00f", screenX + textXOffset, screenY + textYOffset + 9);
        } else {
          tft.drawString("GND", screenX + textXOffset, screenY + textYOffset + 9);
        }
      }
    }
    
    tft.fillRect(75, 8, 90, 18, TFT_BLACK);  
    tft.fillRect(65, 213, 110, 18, TFT_BLACK); 
    drawRadarGrid(); 

    tft.setTextColor(TFT_GREEN);
    tft.drawCentreString("RIX RADAR", 120, 10, 2);     
    tft.drawCentreString("TRAFFIC: " + String(plottedCount), 120, 215, 2); 
    
    if (plottedCount == 0) {
      tft.drawCentreString("SKY CLEAR", 120, 115, 2);
    }
  } 
  else {
    Serial.printf("HTTP Failed: %d\n", httpCode);
    tft.fillRect(30, 110, 180, 20, TFT_BLACK);
    
    if (httpCode == 429) {
      tft.drawCentreString("RATE COOLDOWN", 120, 112, 2);
      backoffSeconds = 60; 
    } else {
      tft.drawCentreString("API ERR: " + String(httpCode), 120, 112, 2);
      backoffSeconds = 20;
    }
  }
  http.end();
}

void drawRadarGrid() {
  tft.drawCircle(120, 120, 35,  TFT_DARKGREEN); 
  tft.drawCircle(120, 120, 75,  TFT_DARKGREEN); 
  tft.drawCircle(120, 120, 115, TFT_GREEN);     
  
  tft.drawFastHLine(5, 120, 230, TFT_DARKGREEN);
  tft.drawFastVLine(120, 5, 230, TFT_DARKGREEN);
  tft.drawRect(118, 118, 4, 4, TFT_GREEN);
}
